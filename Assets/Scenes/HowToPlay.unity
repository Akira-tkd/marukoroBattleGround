  disactiveStage: 050000000b00000017000000
  informationText:
  - "\u3088\u3046\u3053\u305D\\n\u307E\u308B\u3053\u308DBattleGround\u306E\u4E16\u754C\u3078\uFF01\uFF01"
  - "\u3053\u3053\u3067\u306F\u307E\u308B\u3053\u308D\u306E\\n\u64CD\u4F5C\u65B9\u6CD5\u3092\u77E5\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
  - "\u307E\u305A\u306F\u524D\u5F8C\u5DE6\u53F3\u306B\u79FB\u52D5\u3057\u3066\u307F\u307E\u3057\u3087\u3046"
  - "W\u3067\u524D\u9032\u3001S\u3067\u5F8C\u9000\\nA\u3067\u5DE6\u306B\u3001D\u3067\u53F3\u306B\u79FB\u52D5\u3057\u307E\u3059"
  - "\u3053\u306E\u79FB\u52D5\u3092\u99C6\u4F7F\u3057\u3066\\n\u8D64\u3044\u30A8\u30EA\u30A2\u306B\u79FB\u52D5\u3057\u3066\u307F\u307E\u3057\u3087\u3046\uFF01"
  - "\u304A\u898B\u4E8B\uFF01\\n\u3053\u308C\u3067\u524D\u5F8C\u5DE6\u53F3\u306E\u79FB\u52D5\u306F\u554F\u984C\u306A\u3044\u3067\u3057\u3087\u3046"
  - "\u6B21\u306F\\n\u30B8\u30E3\u30F3\u30D7\u3068\u30DB\u30D0\u30FC\u3092\u3084\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
  - "\u30B9\u30DA\u30FC\u30B9\u30AD\u30FC\u3092\u62BC\u3059\u3053\u3068\u3067\\n\u98DB\u3073\u4E0A\u304C\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
  - "\u3082\u3046\u4E00\u5EA6\u7A7A\u4E2D\u3067\u30B9\u30DA\u30FC\u30B9\u30AD\u30FC\u3092\u62BC\u3059\u3053\u3068\u3067\\n\u62BC\u3057\u3066\u3044\u308B\u9593\u3060\u3051\u5DE6\u4E0A\u306E\\n\u6C34\u8272\u306E\u30B2\u30FC\u30B8\u3092\u6D88\u8CBB\u3057\u3066\\n\u7A7A\u4E2D\u306B\u6D6E\u304B\u3076\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
  - "\u6B21\u306F\u3053\u306E\u30B8\u30E3\u30F3\u30D7\u3068\u30DB\u30D0\u30FC\u3082\u99C6\u4F7F\u3057\u3066\\n\u4E0A\u306E\u65B9\u306B\u3042\u308B\u8D64\u30A8\u30EA\u30A2\u3092\u76EE\u6307\u3057\u307E\u3057\u3087\u3046\uFF01"
  - "\u5B8C\u74A7\u3067\u3059\u306D\uFF01\\n\u3053\u308C\u3067\u3053\u306E\u30B2\u30FC\u30E0\u3067\u306E\u79FB\u52D5\u306B\u95A2\u3057\u3066\\n\u3042\u306A\u305F\u306F\u30DE\u30B9\u30BF\u30FC\u3057\u307E\u3057\u305F\uFF01"
  - "\u6700\u5F8C\u306B\u653B\u6483\u306B\u3064\u3044\u3066\u6559\u3048\u307E\u3057\u3087\u3046"
  - "\u653B\u6483\u306F\u5DE6\u30AF\u30EA\u30C3\u30AF\u3068\u53F3\u30AF\u30EA\u30C3\u30AF\u3067\\n\u4E8C\u7A2E\u985E\u306E\u653B\u6483\u3092\u6253\u3061\u5206\u3051\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
  - "\u9577\u62BC\u3057\u3059\u308B\u3060\u3051\u3067\u9023\u5C04\u3067\u304D\u308B\u306E\u3067\\n\u9023\u6253\u306F\u4E0D\u8981\u3067\u3059"
  - "\u307E\u305F\u3001\u653B\u6483\u306B\u306F\u30AF\u30FC\u30EB\u30BF\u30A4\u30E0\u304C\u3042\u308A\\n\u3053\u308C\u306F\u5404\u30AF\u30EA\u30C3\u30AF\u3054\u3068\u306B\u72EC\u7ACB\u3057\u3066\u3044\u307E\u305B\u3093"
  - "\u3064\u307E\u308A\u3001\u53F3\u30AF\u30EA\u30C3\u30AF\u3067\u306E\u653B\u6483\u306B\u3088\u308B\\n\u30AF\u30FC\u30EB\u30BF\u30A4\u30E0\u4E2D\u306F\u5DE6\u30AF\u30EA\u30C3\u30AF\u306E\u653B\u6483\u304C\\n\u51FA\u6765\u306A\u3044\u3068\u3044\u3046\u3053\u3068\u3067\u3059\\n\u9006\u3082\u307E\u305F\u540C\u3058\u3067\u3059"
  - "\u57FA\u672C\u7684\u306B\u53F3\u30AF\u30EA\u30C3\u30AF\u306B\u3088\u308B\u653B\u6483\u306F\\n\u30AF\u30FC\u30EB\u30BF\u30A4\u30E0\u304C\u9577\u304F\u5F37\u529B\u306A\u3082\u306E\\n\u5DE6\u30AF\u30EA\u30C3\u30AF\u306B\u3088\u308B\u653B\u6483\u306F\\n\u9023\u5C04\u6027\u306B\u512A\u308C\u305F\u4FBF\u5229\u306A\u3082\u306E\u306B\u306A\u3063\u3066\u3044\u307E\u3059"
  - "\u3067\u306F\u65E9\u901F\u653B\u6483\u3092\u8A66\u3057\u3066\u307F\u307E\u3057\u3087\u3046\\n\u3053\u3053\u306B\u306F\u6575\u304C\u3044\u306A\u304F\u3066\u5BC2\u3057\u3044\u3067\u3059\u304C..."
  - "\u3061\u306A\u307F\u306B\u3001\u5341\u5206\u653B\u6483\u3092\u8A66\u305B\u305F\u3068\u601D\u3063\u305F\u3089\\nM\u30AD\u30FC\u3067\u30E1\u30A4\u30F3\u30E1\u30CB\u30E5\u30FC\u306B\u623B\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059"
  - "\u3053\u308C\u306F\u5B9F\u969B\u306E\u30D7\u30EC\u30A4\u4E2D\u3067\u3082\u540C\u69D8\u3067\u3059\u306E\u3067\\n\u61B6\u3048\u3066\u304A\u304D\u307E\u3057\u3087\u3046"
  - "\u305D\u308C\u3067\u306F\u3001\u307E\u305F\u304A\u4F1A\u3044\u3057\u307E\u3057\u3087\u3046"
  textObject: {fileID: 72756439}
